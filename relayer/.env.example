# Relayer Configuration
PORT=3000
REQUEST_TTL_SECONDS=900

# Sui Configuration (required)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Testnet: 0xba8a26d42bc8b5e5caf4dac2a0f7544128d5dd9b4614af88eec1311ade11de79
# Mainnet: 0x541840ae7df705d1c6329c22415ed61f9140a18b79b13c1c9dc7415b115c1ba8
GROUPS_PACKAGE_ID=

# Storage (optional — defaults to in-memory)
STORAGE_TYPE=memory
MEMBERSHIP_STORE_TYPE=memory

# Walrus Configuration (optional — defaults to testnet)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_STORAGE_EPOCHS=5
WALRUS_SYNC_INTERVAL_SECS=3600
WALRUS_SYNC_BATCH_SIZE=100
WALRUS_SYNC_MESSAGE_THRESHOLD=50

# Logging (options: error, warn, info, debug, trace)
RUST_LOG=messaging_relayer=info
